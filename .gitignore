# Qt Creator / Qt build folders
**/build-*/

   # 所有 build-* 文件夹
*.pro.user    # Qt Creator 用户配置文件
*.qmake.stash # QMake 临时文件

# Binary and object files
*.o
*.obj
*.a
*.lib
*.so
*.dll
*.exe
*.out
*.app
*.dylib

# Debug/Release folders
Debug/
Release/
bin-debug/
bin-release/

# Visual Studio / IDE files
*.sln
*.vcxproj
*.filters
*.user
*.suo
.vs/

# Other temporary or system files
*.db
*.ipch
*.swp
*.DS_Store
.settings/
